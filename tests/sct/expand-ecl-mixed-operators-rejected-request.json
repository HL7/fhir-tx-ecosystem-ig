        "date": "2025-09-05",
        "publisher": "FHIR Project",
        "description": "Mixed AND and OR operators without parentheses. The SNOMED ECL grammar (compoundExpressionConstraint, ECL v2.2 and v2.3 ABNF) defines a compound expression as exactly one operator type, and the v2.3 spec text requires brackets to disambiguate when binary operators are mixed. Conformant servers must reject this input as invalid ECL.",
        "compose": {
          "include": [
            {
              "system": "http://snomed.info/sct",
              "version": "http://snomed.info/xsct/900000000000207008/version/20250814",
              "filter": [
                {
                  "property": "constraint",
                  "op": "=",
                  "value": "<< 128045006 OR << 10200004 AND << 64572001"
                }
              ]
            }
          ]
        }
      }
    }
  ]
